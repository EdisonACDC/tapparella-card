modules = ["nodejs-20"]

  [nix]
  channel = "stable-24_05"

  [workflows]
  runButton = "Dev Server"

  [[workflows.workflow]]
  name = "Dev Server"
  mode = "sequential"

  [[workflows.workflow.tasks]]
  task = "shell.exec"
  args = "npm install && npm run dev"

  [deployment]
  run = ["sh", "-c", "npm run build && npm run preview"]
  